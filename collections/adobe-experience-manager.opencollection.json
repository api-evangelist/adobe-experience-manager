        {
          "info": {
            "name": "Rebase a launch onto current production content",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://{author-instance}.adobeaemcloud.com/:launchId/rebase",
            "params": [
              {
                "name": "launchId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Rebase a launch onto current production content"
