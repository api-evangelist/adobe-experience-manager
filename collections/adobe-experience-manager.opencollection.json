        {
          "info": {
            "name": "Retrieve content contained in a launch",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{author-instance}.adobeaemcloud.com/:launchId/content",
            "params": [
              {
                "name": "launchId",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Retrieve content contained in a launch"
